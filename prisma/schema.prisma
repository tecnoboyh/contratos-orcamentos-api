generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  USER
}

enum ContractStatus {
  DRAFT
  WAITING_SIGNATURE
  SIGNED
  ACTIVE
  EXPIRING
  CLOSED
  EXPIRED
  CANCELED
}

enum ContractType {
  SERVICE
  WORK
  RENT
  EMPLOYMENT
  OTHER
}

enum SignatureChannel {
  EMAIL
  WHATSAPP
  BOTH
}

enum SignatureStatus {
  PENDING
  SENT
  SIGNED
  EXPIRED
  FAILED
}

enum ObraStatus {
  PLANNING
  IN_PROGRESS
  FINISHED
  CANCELED
}

enum VistoriaType {
  INITIAL
  FINAL
}

enum CostCategory {
  MATERIAL
  LABOR
  EQUIPMENT
  SERVICE
  OTHER
}

enum PurchaseOrderStatus {
  DRAFT
  ISSUED
  APPROVED
  CANCELED
}

model Company {
  id        String   @id @default(uuid())
  name      String
  cnpj      String?  @unique
  email     String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users             User[]
  contracts         Contract[]
  contractTemplates ContractTemplate[]
  obras             Obra[]
  purchaseOrders    PurchaseOrder[]
  uploads           Upload[]
  auditLogs         AuditLog[]
  members           CompanyMember[]

  @@map("companies")
}

enum CompanyMemberRole {
  OWNER
  ADMIN
  MEMBER
}

model User {
  id           String   @id @default(uuid())
  companyId    String
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(USER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company        Company         @relation(fields: [companyId], references: [id])
  auditLogs      AuditLog[]
  companyMembers CompanyMember[]

  @@map("users")
}

model CompanyMember {
  id        String            @id @default(uuid())
  companyId String
  userId    String
  role      CompanyMemberRole @default(ADMIN)
  createdAt DateTime          @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId])
  @@map("company_members")
}

model ContractTemplate {
  id          String       @id @default(uuid())
  companyId   String
  name        String
  type        ContractType
  description String?
  content     String
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  company   Company                 @relation(fields: [companyId], references: [id])
  fields    ContractTemplateField[]
  contracts Contract[]

  @@map("contract_templates")
}

model ContractTemplateField {
  id         String   @id @default(uuid())
  templateId String
  label      String
  key        String
  type       String
  required   Boolean  @default(false)
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  template ContractTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@map("contract_template_fields")
}

model Contract {
  id             String         @id @default(uuid())
  companyId      String
  templateId     String?
  title          String
  type           ContractType
  status         ContractStatus @default(DRAFT)
  relatedParty   String
  documentNumber String?
  totalValue     Decimal?       @db.Decimal(12, 2)
  monthlyValue   Decimal?       @db.Decimal(12, 2)
  startDate      DateTime?
  endDate        DateTime?
  content        String?
  filledFields   Json?
  signedAt       DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  archivedAt     DateTime?

  company           Company            @relation(fields: [companyId], references: [id])
  template          ContractTemplate?  @relation(fields: [templateId], references: [id])
  signatureRequests SignatureRequest[]
  obras             Obra[]
  uploads           Upload[]
  purchaseOrders    PurchaseOrder[]

  @@map("contracts")
}

model SignatureRequest {
  id           String           @id @default(uuid())
  contractId   String
  channel      SignatureChannel
  status       SignatureStatus  @default(PENDING)
  signerName   String
  signerEmail  String?
  signerPhone  String?
  signatureUrl String?
  sentAt       DateTime?
  signedAt     DateTime?
  expiresAt    DateTime?
  attempts     Int              @default(0)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@map("signature_requests")
}

model Obra {
  id             String     @id @default(uuid())
  companyId      String
  contractId     String?
  name           String
  description    String?
  location       String?
  status         ObraStatus @default(PLANNING)
  expectedBudget Decimal?   @db.Decimal(12, 2)
  realizedBudget Decimal?   @db.Decimal(12, 2)
  startDate      DateTime?
  endDate        DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  company        Company         @relation(fields: [companyId], references: [id])
  contract       Contract?       @relation(fields: [contractId], references: [id])
  steps          ObraStep[]
  vistorias      ObraVistoria[]
  custos         ObraCusto[]
  purchaseOrders PurchaseOrder[]
  uploads        Upload[]

  @@map("obras")
}

model ObraStep {
  id          String    @id @default(uuid())
  obraId      String
  title       String
  description String?
  phase       String
  isCompleted Boolean   @default(false)
  completedAt DateTime?
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  obra Obra @relation(fields: [obraId], references: [id], onDelete: Cascade)

  @@map("obra_steps")
}

model ObraVistoria {
  id          String       @id @default(uuid())
  obraId      String
  type        VistoriaType
  description String?
  performedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  obra    Obra     @relation(fields: [obraId], references: [id], onDelete: Cascade)
  uploads Upload[]

  @@map("obra_vistorias")
}

model ObraCusto {
  id          String       @id @default(uuid())
  obraId      String
  description String
  category    CostCategory
  amount      Decimal      @db.Decimal(12, 2)
  paidAt      DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  obra Obra @relation(fields: [obraId], references: [id], onDelete: Cascade)

  @@map("obra_custos")
}

model PurchaseOrder {
  id          String              @id @default(uuid())
  companyId   String
  obraId      String
  contractId  String?
  number      String
  payerCnpj   String
  supplier    String?
  description String?
  totalValue  Decimal             @db.Decimal(12, 2)
  status      PurchaseOrderStatus @default(DRAFT)
  issuedAt    DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  company  Company   @relation(fields: [companyId], references: [id])
  obra     Obra      @relation(fields: [obraId], references: [id])
  contract Contract? @relation(fields: [contractId], references: [id])

  @@unique([companyId, number])
  @@map("purchase_orders")
}

model Upload {
  id         String   @id @default(uuid())
  companyId  String
  contractId String?
  obraId     String?
  vistoriaId String?
  fileName   String
  fileUrl    String
  mimeType   String?
  size       Int?
  createdAt  DateTime @default(now())

  company  Company       @relation(fields: [companyId], references: [id])
  contract Contract?     @relation(fields: [contractId], references: [id])
  obra     Obra?         @relation(fields: [obraId], references: [id])
  vistoria ObraVistoria? @relation(fields: [vistoriaId], references: [id])

  @@map("uploads")
}

model AuditLog {
  id        String   @id @default(uuid())
  companyId String
  userId    String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id])
  user    User?   @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}
